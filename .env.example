# Backend — LLM: Ollama (free, local). No key required.
# Install Ollama from https://ollama.com then run e.g.: ollama run llama3.2
OLLAMA_MODEL=llama3.2
# OLLAMA_HOST=http://localhost:11434

# Optional: use OpenAI instead when set (takes precedence if Ollama fails)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Frontend (optional — defaults to http://localhost:8000)
# NEXT_PUBLIC_API_URL=http://localhost:8000
